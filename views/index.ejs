<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Plataforma de Salud Industrial 4.0</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
</head>
<body class="font-sans antialiased p-4 min-h-screen flex flex-col justify-between">

    <header class="bg-secondary p-4 rounded-xl flex justify-between items-center mb-4 border border-gray-800 shadow-md">
        <div class="flex items-center space-x-3">
            <i class="fa-solid fa-industry text-2xl color-azul"></i>
            <h1 class="text-xl font-bold tracking-wide">Plataforma de Salud Industrial 4.0</h1>
        </div>
        <div class="flex items-center space-x-6 text-sm">
            <div class="flex items-center space-x-2">
                <span class="text-secondary-custom">Conexión PLC:</span>
                <span class="inline-block w-3 h-3 bg-green-500 rounded-full animate-pulse"></span>
                <span class="font-semibold text-green-500" id="plc-status">CONECTADO</span>
            </div>
            <div>
                <span class="text-secondary-custom">Hora UTC:</span>
                <span class="font-mono font-bold" id="utc-time">00:00:00</span>
            </div>
        </div>
    </header>

    <div class="grid grid-cols-1 xl:grid-cols-4 gap-4 flex-grow">

        <div class="xl:col-span-1 flex flex-col space-y-4">
            <div class="bg-secondary p-4 rounded-xl border border-gray-800">
                <label class="block text-xs font-semibold uppercase text-secondary-custom mb-2">Activo Seleccionado</label>
                <select class="w-full bg-panel border border-gray-700 rounded-lg p-3 text-sm font-medium focus:outline-none appearance-none cursor-pointer">
                    <option>🎛️ Prensa 1</option>
                    <option>🎛️ Prensa 2</option>
                </select>
            </div>

            <div class="bg-secondary p-4 rounded-xl border border-gray-800 flex-grow">
                <h3 class="text-xs font-semibold uppercase text-secondary-custom mb-3">Herramientas / Acciones</h3>
                <div class="space-y-2 text-xs">
                    <button class="w-full text-left bg-panel hover:bg-gray-800 border-l-4 border-blue-500 p-3 rounded-r-lg flex items-center space-x-3 transition">
                        <i class="fa-solid fa-play color-azul text-base w-4"></i>
                        <div><p class="font-bold">Tool 1: Iniciar Monitoreo</p><p class="text-secondary-custom text-[10px]">Activa la captura de datos</p></div>
                    </button>
                    <button class="w-full text-left bg-panel hover:bg-gray-800 border-l-4 border-yellow-500 p-3 rounded-r-lg flex items-center space-x-3 transition">
                        <i class="fa-solid fa-sliders color-alerta text-base w-4"></i>
                        <div><p class="font-bold">Tool 2: Calibrar Sensores</p><p class="text-secondary-custom text-[10px]">Ejecuta rutina de calibración</p></div>
                    </button>
                    <button class="w-full text-left bg-panel hover:bg-gray-800 border-l-4 border-green-500 p-3 rounded-r-lg flex items-center space-x-3 transition">
                        <i class="fa-solid fa-gears color-exito text-base w-4"></i>
                        <div><p class="font-bold">Tool 3: Ajuste de Proceso</p><p class="text-secondary-custom text-[10px]">Envía setpoint al PLC</p></div>
                    </button>
                    <button class="w-full text-left bg-panel hover:bg-gray-800 border-l-4 border-purple-500 p-3 rounded-r-lg flex items-center space-x-3 transition">
                        <i class="fa-solid fa-circle-pause color-morado text-base w-4"></i>
                        <div><p class="font-bold">Tool 4: Pausa de Línea</p><p class="text-secondary-custom text-[10px]">Pausa segura de operación</p></div>
                    </button>
                    <button class="w-full text-left bg-panel hover:bg-gray-800 border-l-4 border-red-500 p-3 rounded-r-lg flex items-center space-x-3 transition">
                        <i class="fa-solid fa-bell color-critico text-base w-4"></i>
                        <div><p class="font-bold">Tool 5: Simular Falla</p><p class="text-secondary-custom text-[10px]">Eleva vibración / temperatura</p></div>
                    </button>
                </div>
            </div>

            <div class="bg-secondary p-4 rounded-xl border border-gray-800 text-xs">
                <h3 class="font-semibold uppercase text-secondary-custom mb-3">Información del Activo</h3>
                <div class="space-y-2">
                    <div class="flex justify-between"><span class="text-secondary-custom">Tipo:</span><span>Prensa Hidráulica</span></div>
                    <div class="flex justify-between"><span class="text-secondary-custom">Ubicación:</span><span>Planta 1 - Línea A</span></div>
                    <div class="flex justify-between"><span class="text-secondary-custom">ID Activo:</span><span>PRN-001</span></div>
                    <div class="flex justify-between items-center"><span class="text-secondary-custom">Estado Operativo:</span><span class="bg-green-950 text-green-400 px-2 py-0.5 rounded border border-green-800 font-bold">EN PRODUCCIÓN</span></div>
                </div>
            </div>
        </div>

        <div class="xl:col-span-2 flex flex-col space-y-4">
            <div class="grid grid-cols-3 gap-3">
                <div class="bg-secondary p-4 rounded-xl border border-gray-800 text-center">
                    <p class="text-xs text-secondary-custom mb-1">Temperatura Motor</p>
                    <p class="text-2xl font-mono font-bold" id="val-temp">0.0 <span class="text-sm">°C</span></p>
                    <span class="text-[10px] text-green-400"><i class="fa-solid fa-circle text-[8px]"></i> Normal &lt; 80°C</span>
                </div>
                <div class="bg-secondary p-4 rounded-xl border border-gray-800 text-center">
                    <p class="text-xs text-secondary-custom mb-1">Vibración RMS</p>
                    <p class="text-2xl font-mono font-bold" id="val-vib">0.0 <span class="text-sm">mm/s</span></p>
                    <span class="text-[10px] text-green-400"><i class="fa-solid fa-circle text-[8px]"></i> Normal &lt; 7.1 mm/s</span>
                </div>
                <div class="bg-secondary p-4 rounded-xl border border-gray-800 text-center">
                    <p class="text-xs text-secondary-custom mb-1">Presión Hidráulica</p>
                    <p class="text-2xl font-mono font-bold" id="val-pres">0 <span class="text-sm">bar</span></p>
                    <span class="text-[10px] text-green-400"><i class="fa-solid fa-circle text-[8px]"></i> Normal 150-250</span>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 bg-secondary p-4 rounded-xl border border-gray-800 flex-grow">
                <div>
                    <h4 class="text-xs text-secondary-custom mb-2">Tendencia de Vibración RMS (mm/s)</h4>
                    <div class="h-44"><canvas id="chartVibracion"></canvas></div>
                </div>
                <div>
                    <h4 class="text-xs text-secondary-custom mb-2">Tendencia de Temperatura (°C)</h4>
                    <div class="h-44"><canvas id="chartTemperatura"></canvas></div>
                </div>
            </div>

            <div class="bg-secondary p-4 rounded-xl border border-gray-800 grid grid-cols-3 gap-4 items-center">
                <div class="text-center">
                    <p class="text-xs text-secondary-custom mb-2">Salud Mecánica</p>
                    <p class="text-3xl font-bold text-green-400" id="ia-salud">0%</p>
                    <span class="text-[10px] text-green-400 font-bold">✓ Riesgo Bajo</span>
                </div>
                <div class="text-center">
                    <p class="text-xs text-secondary-custom mb-2">Riesgo de Calidad</p>
                    <p class="text-3xl font-bold color-alerta" id="ia-calidad">0%</p>
                    <span class="text-[10px] color-alerta font-bold">⚠️ Riesgo Moderado</span>
                </div>
                <div class="bg-panel p-3 rounded-lg border border-yellow-600 text-center flex flex-col items-center justify-center">
                    <i class="fa-solid fa-triangle-exclamation text-2xl color-alerta mb-1"></i>
                    <p class="text-xs font-bold uppercase color-alerta" id="ia-estado-txt">ESTADO: OK</p>
                    <p class="text-[9px] text-secondary-custom">Monitoreo activo</p>
                </div>
            </div>
        </div>

        <div class="xl:col-span-1 bg-secondary p-4 rounded-xl border border-gray-800 flex flex-col h-full min-h-[450px]">
            <div class="flex justify-between items-center mb-3">
                <h3 class="text-xs font-semibold uppercase text-secondary-custom">Monitor de Eventos IES</h3>
                <button class="text-xs bg-panel px-2 py-1 rounded border border-gray-700 text-secondary-custom hover:text-white"><i class="fa-solid fa-filter"></i> Filtrar</button>
            </div>
            <div id="logger-console" class="flex-grow bg-black rounded-lg p-3 font-mono text-[11px] overflow-y-auto space-y-3 max-h-[550px] border border-gray-900 shadow-inner">
                </div>
        </div>
    </div>

    <script src="app.js"></script>
</body>
</html>